# Build artifacts (everything intermediate now lands under build/)
/build/

# Compiled outputs anywhere in the tree
*.o
*.elf
*.bin

# Disk images (all generated by the Makefile / mkfs)
*.img

# QEMU / debug logs
*.log

# Python tooling caches
__pycache__/
*.pyc

# clangd index database -- machine-specific absolute paths; regenerate with
# `make compile-commands` (tools/gen_compile_commands.py)
/compile_commands.json
/.cache/
